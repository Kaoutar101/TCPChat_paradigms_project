<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.chatapp.server.view.ServerController"
      spacing="10"
      style="-fx-background-color: #1e1e2e; -fx-padding: 15;">

    <!-- Title -->
    <Label text="TCPChat Server"
           style="-fx-text-fill: #cdd6f4; -fx-font-size: 20px;
                  -fx-font-weight: bold;"/>

    <HBox spacing="10">

        <!-- Connected Users -->
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Connected Users"
                   style="-fx-text-fill: #a6adc8; -fx-font-size: 13px;"/>
            <ListView fx:id="usersListView"
                      VBox.vgrow="ALWAYS"
                      prefHeight="400"
                      style="-fx-background-color: #181825;
                             -fx-border-color: #313244;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;"/>
        </VBox>

        <!-- Server Log -->
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Server Log"
                   style="-fx-text-fill: #a6adc8; -fx-font-size: 13px;"/>
            <TextArea fx:id="logArea"
                      editable="false"
                      wrapText="true"
                      prefHeight="400"
                      VBox.vgrow="ALWAYS"
                      style="-fx-control-inner-background: #181825;
                             -fx-text-fill: #cdd6f4;
                             -fx-font-size: 12px;
                             -fx-border-color: #313244;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;"/>
        </VBox>

    </HBox>

</VBox>
